{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/omarespejel/provable-transformer-vm/.codex/research/schemas/agent_brief.schema.json",
  "type": "object",
  "required": ["schema_version", "role", "mission", "output_contract"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "role": {
      "type": "string",
      "enum": ["scout", "experimenter", "skeptic", "integrator"]
    },
    "mission": { "type": "string", "minLength": 1 },
    "inputs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "allowed_actions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "forbidden_actions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "required_behavior": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "attack_checklist": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "output_contract": {
      "type": "object",
      "minProperties": 1,
      "properties": {
        "required_fields": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "default_status": { "type": "string", "minLength": 1 },
        "success": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "failure": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false,
      "anyOf": [
        { "required": ["required_fields"] },
        { "required": ["success", "failure"] }
      ]
    }
  },
  "additionalProperties": true
}
