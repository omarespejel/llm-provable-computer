{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/omarespejel/provable-transformer-vm/.codex/research/schemas/operating_model.schema.json",
  "type": "object",
  "required": [
    "schema_version",
    "model_id",
    "work_allocation",
    "unit_of_work",
    "agent_roles",
    "validation_policy",
    "review_bot_policy",
    "merge_policy",
    "claim_discipline"
  ],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "model_id": { "type": "string", "minLength": 1 },
    "work_allocation": {
      "type": "object",
      "required": ["exploration_share", "execution_share"],
      "properties": {
        "exploration_share": { "type": "number", "minimum": 0, "maximum": 1 },
        "execution_share": { "type": "number", "minimum": 0, "maximum": 1 },
        "interpretation": { "type": "string" }
      },
      "additionalProperties": true
    },
    "unit_of_work": { "type": "object" },
    "agent_roles": { "type": "object" },
    "validation_policy": { "type": "object" },
    "review_bot_policy": { "type": "object" },
    "merge_policy": { "type": "object" },
    "claim_discipline": { "type": "object" }
  },
  "additionalProperties": true
}
