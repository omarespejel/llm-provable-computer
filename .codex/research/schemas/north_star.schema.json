{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/omarespejel/provable-transformer-vm/.codex/research/schemas/north_star.schema.json",
  "type": "object",
  "required": [
    "schema_version",
    "program_id",
    "north_star",
    "primary_thesis",
    "paper_candidate_claim",
    "forbidden_claims",
    "promotion_requirements"
  ],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "program_id": { "type": "string", "minLength": 1 },
    "last_reviewed": { "type": "string" },
    "north_star": { "type": "string", "minLength": 1 },
    "primary_thesis": { "type": "string", "minLength": 1 },
    "paper_candidate_claim": { "type": "object" },
    "target_narrative": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "forbidden_claims": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "promotion_requirements": { "type": "object" },
    "default_question_for_agents": { "type": "string" }
  },
  "additionalProperties": true
}
