{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://llm-provable-computer/spec/statement-v2-one-step-certificate.schema.json",
  "title": "Statement V2 One-Step Semantic Certificate",
  "type": "object",
  "required": [
    "statement_version",
    "semantic_scope",
    "fixed_point_profile",
    "onnx_op_subset_version",
    "program_path",
    "checked_steps",
    "matched",
    "commitments"
  ],
  "properties": {
    "statement_version": { "type": "string" },
    "semantic_scope": { "type": "string" },
    "fixed_point_profile": { "type": "string" },
    "onnx_op_subset_version": { "type": "string" },
    "program_path": { "type": "string" },
    "checked_steps": { "type": "integer", "minimum": 1 },
    "matched": { "type": "boolean" },
    "commitments": {
      "type": "object",
      "required": [
        "hash_function",
        "statement_spec_hash",
        "fixed_point_spec_hash",
        "onnx_op_subset_hash",
        "artifact_schema_hash",
        "program_hash",
        "transformer_config_hash",
        "onnx_metadata_hash",
        "state_before_hash",
        "transformer_state_after_hash",
        "onnx_state_after_hash"
      ],
      "properties": {
        "hash_function": { "type": "string" },
        "statement_spec_hash": { "type": "string" },
        "fixed_point_spec_hash": { "type": "string" },
        "onnx_op_subset_hash": { "type": "string" },
        "artifact_schema_hash": { "type": "string" },
        "program_hash": { "type": "string" },
        "transformer_config_hash": { "type": "string" },
        "onnx_metadata_hash": { "type": "string" },
        "state_before_hash": { "type": "string" },
        "transformer_state_after_hash": { "type": "string" },
        "onnx_state_after_hash": { "type": "string" }
      }
    }
  }
}
