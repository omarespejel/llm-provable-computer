{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://llm-provable-computer/spec/stwo-phase34-recursive-compression-shared-lookup-manifest.schema.json",
  "title": "S-two Phase 34 Recursive Compression Shared Lookup Manifest",
  "type": "object",
  "required": [
    "proof_backend",
    "manifest_version",
    "semantic_scope",
    "proof_backend_version",
    "statement_version",
    "step_relation",
    "required_recursion_posture",
    "recursive_verification_claimed",
    "cryptographic_compression_claimed",
    "phase33_manifest_version",
    "phase33_semantic_scope",
    "phase33_recursive_public_inputs_commitment",
    "phase30_manifest_version",
    "phase30_semantic_scope",
    "phase30_source_chain_commitment",
    "phase30_step_envelopes_commitment",
    "total_steps",
    "input_lookup_rows_commitments_commitment",
    "output_lookup_rows_commitments_commitment",
    "shared_lookup_artifact_commitments_commitment",
    "static_lookup_registry_commitments_commitment",
    "shared_lookup_public_inputs_commitment"
  ],
  "properties": {
    "proof_backend": { "const": "stwo" },
    "manifest_version": {
      "const": "stwo-phase34-recursive-compression-shared-lookup-manifest-v1"
    },
    "semantic_scope": {
      "const": "stwo_execution_parameterized_recursive_compression_shared_lookup_manifest"
    },
    "proof_backend_version": { "const": "stwo-phase12-decoding-family-v9" },
    "statement_version": { "const": "statement-v1" },
    "step_relation": { "const": "decoding_step_v2" },
    "required_recursion_posture": {
      "const": "pre-recursive-proof-carrying-aggregation"
    },
    "recursive_verification_claimed": { "const": false },
    "cryptographic_compression_claimed": { "const": false },
    "phase33_manifest_version": {
      "const": "stwo-phase33-recursive-compression-public-input-manifest-v1"
    },
    "phase33_semantic_scope": {
      "const": "stwo_execution_parameterized_recursive_compression_public_input_manifest"
    },
    "phase33_recursive_public_inputs_commitment": {
      "$ref": "#/$defs/hash_blake2b_256_hex"
    },
    "phase30_manifest_version": {
      "const": "stwo-phase30-decoding-step-proof-envelope-manifest-v1"
    },
    "phase30_semantic_scope": {
      "const": "stwo_execution_parameterized_decoding_step_proof_envelope_manifest"
    },
    "phase30_source_chain_commitment": { "$ref": "#/$defs/hash_blake2b_256_hex" },
    "phase30_step_envelopes_commitment": { "$ref": "#/$defs/hash_blake2b_256_hex" },
    "total_steps": { "type": "integer", "minimum": 1 },
    "input_lookup_rows_commitments_commitment": {
      "$ref": "#/$defs/hash_blake2b_256_hex"
    },
    "output_lookup_rows_commitments_commitment": {
      "$ref": "#/$defs/hash_blake2b_256_hex"
    },
    "shared_lookup_artifact_commitments_commitment": {
      "$ref": "#/$defs/hash_blake2b_256_hex"
    },
    "static_lookup_registry_commitments_commitment": {
      "$ref": "#/$defs/hash_blake2b_256_hex"
    },
    "shared_lookup_public_inputs_commitment": {
      "$ref": "#/$defs/hash_blake2b_256_hex"
    }
  },
  "$defs": {
    "hash_blake2b_256_hex": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  },
  "additionalProperties": false
}
