{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://llm-provable-computer/spec/statement-v2-matrix-certificate.schema.json",
  "title": "Statement V2 Matrix Prefix Trace Semantic Certificate",
  "type": "object",
  "required": [
    "statement_version",
    "semantic_scope",
    "fixed_point_profile",
    "onnx_op_subset_version",
    "requested_max_steps",
    "total_programs",
    "matched_programs",
    "mismatched_programs",
    "entries",
    "commitments"
  ],
  "properties": {
    "statement_version": { "type": "string" },
    "semantic_scope": { "type": "string" },
    "fixed_point_profile": { "type": "string" },
    "onnx_op_subset_version": { "type": "string" },
    "requested_max_steps": { "type": "integer", "minimum": 1 },
    "total_programs": { "type": "integer", "minimum": 1 },
    "matched_programs": { "type": "integer", "minimum": 0 },
    "mismatched_programs": { "type": "integer", "minimum": 0 },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "program_path",
          "checked_steps",
          "matched",
          "commitments"
        ],
        "properties": {
          "program_path": { "type": "string" },
          "checked_steps": { "type": "integer", "minimum": 0 },
          "matched": { "type": "boolean" },
          "first_mismatch_step": { "type": ["integer", "null"] },
          "mismatch_reason": { "type": ["string", "null"] },
          "commitments": {
            "type": "object",
            "required": [
              "hash_function",
              "program_hash",
              "transformer_config_hash",
              "onnx_metadata_hash",
              "transformer_trace_hash",
              "onnx_trace_hash"
            ],
            "properties": {
              "hash_function": { "type": "string" },
              "program_hash": { "type": "string" },
              "transformer_config_hash": { "type": "string" },
              "onnx_metadata_hash": { "type": "string" },
              "transformer_trace_hash": { "type": "string" },
              "onnx_trace_hash": { "type": "string" }
            }
          }
        }
      }
    },
    "commitments": {
      "type": "object",
      "required": [
        "hash_function",
        "statement_spec_hash",
        "fixed_point_spec_hash",
        "onnx_op_subset_hash",
        "artifact_schema_hash",
        "matrix_entries_hash"
      ],
      "properties": {
        "hash_function": { "type": "string" },
        "statement_spec_hash": { "type": "string" },
        "fixed_point_spec_hash": { "type": "string" },
        "onnx_op_subset_hash": { "type": "string" },
        "artifact_schema_hash": { "type": "string" },
        "matrix_entries_hash": { "type": "string" }
      }
    }
  }
}
