    "cryptographic_compression_claimed": { "const": false },
    "phase29_input_contract_verified": { "const": true },
    "phase30_step_envelope_manifest_verified": { "const": true },
    "phase31_decode_boundary_bridge_verified": { "const": true },
    "phase32_statement_contract_verified": { "const": true },
    "phase33_public_inputs_verified": { "const": true },
    "phase34_shared_lookup_verified": { "const": true },
    "phase35_target_manifest_verified": { "const": true },
    "phase36_verifier_harness_receipt_verified": { "const": true },
    "source_binding_verified": { "const": true },
    "phase29_contract_version": { "const": "stwo-phase29-recursive-compression-input-contract-v1" },
    "phase29_semantic_scope": { "const": "stwo_phase29_recursive_compression_input_contract" },
    "phase29_input_contract_commitment": { "$ref": "#/$defs/hash32" },
    "phase30_manifest_version": { "const": "stwo-phase30-decoding-step-proof-envelope-manifest-v1" },
    "phase30_semantic_scope": { "const": "stwo_execution_parameterized_decoding_step_proof_envelope_manifest" },
    "phase30_source_chain_commitment": { "$ref": "#/$defs/hash32" },
    "phase30_step_envelopes_commitment": { "$ref": "#/$defs/hash32" },
    "phase31_decode_boundary_bridge_commitment": { "$ref": "#/$defs/hash32" },
    "phase32_recursive_statement_contract_commitment": { "$ref": "#/$defs/hash32" },
    "phase33_recursive_public_inputs_commitment": { "$ref": "#/$defs/hash32" },
    "phase34_shared_lookup_public_inputs_commitment": { "$ref": "#/$defs/hash32" },
    "phase35_recursive_target_manifest_commitment": { "$ref": "#/$defs/hash32" },
    "phase36_recursive_verifier_harness_receipt_commitment": { "$ref": "#/$defs/hash32" },
    "total_steps": { "type": "integer", "minimum": 1 },
    "chain_start_boundary_commitment": { "$ref": "#/$defs/hash32" },
    "chain_end_boundary_commitment": { "$ref": "#/$defs/hash32" },
    "source_template_commitment": { "$ref": "#/$defs/hash32" },
    "aggregation_template_commitment": { "$ref": "#/$defs/hash32" },
    "input_lookup_rows_commitments_commitment": { "$ref": "#/$defs/hash32" },
    "output_lookup_rows_commitments_commitment": { "$ref": "#/$defs/hash32" },
    "shared_lookup_artifact_commitments_commitment": { "$ref": "#/$defs/hash32" },
    "static_lookup_registry_commitments_commitment": { "$ref": "#/$defs/hash32" },
    "recursive_artifact_chain_harness_receipt_commitment": { "$ref": "#/$defs/hash32" }
  },
  "$defs": {
    "hash32": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  }
}
