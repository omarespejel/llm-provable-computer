  "properties": {
    "proof_backend": { "const": "stwo" },
    "receipt_version": { "const": "stwo-phase37-recursive-artifact-chain-harness-receipt-v1" },
    "semantic_scope": { "const": "stwo_execution_parameterized_recursive_artifact_chain_harness_receipt" },
    "verifier_harness": { "const": "source-bound-recursive-artifact-chain-verifier-v1" },
    "proof_backend_version": { "const": "stwo-phase12-decoding-family-v9" },
    "statement_version": { "const": "statement-v1" },
    "step_relation": { "const": "decoding_step_v2" },
    "required_recursion_posture": { "const": "pre-recursive-proof-carrying-aggregation" },
