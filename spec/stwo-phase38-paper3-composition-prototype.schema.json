{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://llm-provable-computer/spec/stwo-phase38-paper3-composition-prototype.schema.json",
  "title": "S-two Phase 38 Paper 3 Composition Prototype",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "proof_backend",
    "prototype_version",
    "semantic_scope",
    "proof_backend_version",
    "statement_version",
    "required_recursion_posture",
    "recursive_verification_claimed",
    "cryptographic_compression_claimed",
    "segment_count",
    "total_steps",
    "chain_start_boundary_commitment",
    "chain_end_boundary_commitment",
    "shared_lookup_identity_commitment",
    "segment_list_commitment",
    "naive_per_step_package_count",
    "composed_segment_package_count",
    "package_count_delta",
    "segments",
    "composition_commitment"
  ],
  "properties": {
    "proof_backend": { "const": "stwo" },
    "prototype_version": { "const": "stwo-phase38-paper3-composition-prototype-v1" },
    "semantic_scope": { "const": "stwo_execution_parameterized_paper3_composition_prototype" },
    "proof_backend_version": { "const": "stwo-phase12-decoding-family-v9" },
    "statement_version": { "const": "statement-v1" },
    "required_recursion_posture": { "const": "pre-recursive-proof-carrying-aggregation" },
    "recursive_verification_claimed": { "const": false },
    "cryptographic_compression_claimed": { "const": false },
    "segment_count": { "type": "integer", "minimum": 2 },
    "total_steps": { "type": "integer", "minimum": 2 },
    "chain_start_boundary_commitment": { "$ref": "#/$defs/hash32" },
    "chain_end_boundary_commitment": { "$ref": "#/$defs/hash32" },
    "shared_lookup_identity_commitment": { "$ref": "#/$defs/hash32" },
    "segment_list_commitment": { "$ref": "#/$defs/hash32" },
    "naive_per_step_package_count": { "type": "integer", "minimum": 2 },
    "composed_segment_package_count": { "type": "integer", "minimum": 2 },
    "package_count_delta": { "type": "integer", "minimum": 0 },
    "segments": {
      "type": "array",
      "minItems": 2,
      "items": { "$ref": "#/$defs/segment" }
    },
    "composition_commitment": { "$ref": "#/$defs/hash32" }
  },
  "$defs": {
    "hash32": {
      "type": "string",
      "minLength": 64,
      "maxLength": 64,
      "pattern": "^[0-9a-f]{64}$"
    },
    "phase29_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proof_backend",
        "contract_version",
        "semantic_scope",
        "phase28_artifact_version",
        "phase28_semantic_scope",
        "phase28_proof_backend_version",
        "statement_version",
        "required_recursion_posture",
        "recursive_verification_claimed",
        "cryptographic_compression_claimed",
        "phase28_bounded_aggregation_arity",
        "phase28_member_count",
        "phase28_member_summaries",
        "phase28_nested_members",
        "total_phase26_members",
        "total_phase25_members",
        "max_nested_chain_arity",
        "max_nested_fold_arity",
        "total_matrices",
        "total_layouts",
        "total_rollups",
        "total_segments",
        "total_steps",
        "lookup_delta_entries",
        "max_lookup_frontier_entries",
        "source_template_commitment",
        "global_start_state_commitment",
        "global_end_state_commitment",
        "aggregation_template_commitment",
        "aggregated_chained_folded_interval_accumulator_commitment",
        "input_contract_commitment"
      ],
      "properties": {
        "proof_backend": { "const": "stwo" },
        "contract_version": { "const": "stwo-phase29-recursive-compression-input-contract-v1" },
        "semantic_scope": { "const": "stwo_phase29_recursive_compression_input_contract" },
        "phase28_artifact_version": { "const": "stwo-phase28-aggregated-chained-folded-intervalized-decoding-state-relation-v1" },
        "phase28_semantic_scope": { "const": "stwo_execution_parameterized_aggregated_chained_folded_intervalized_proof_carrying_decoding_state_relation" },
        "phase28_proof_backend_version": { "const": "stwo-phase12-decoding-family-v9" },
        "statement_version": { "const": "statement-v1" },
        "required_recursion_posture": { "const": "pre-recursive-proof-carrying-aggregation" },
        "recursive_verification_claimed": { "const": false },
        "cryptographic_compression_claimed": { "const": false },
        "phase28_bounded_aggregation_arity": { "type": "integer", "minimum": 2 },
        "phase28_member_count": { "type": "integer", "minimum": 2 },
        "phase28_member_summaries": { "type": "integer", "minimum": 2 },
        "phase28_nested_members": { "type": "integer", "minimum": 2 },
        "total_phase26_members": { "type": "integer", "minimum": 1 },
        "total_phase25_members": { "type": "integer", "minimum": 1 },
        "max_nested_chain_arity": { "type": "integer", "minimum": 1 },
        "max_nested_fold_arity": { "type": "integer", "minimum": 1 },
        "total_matrices": { "type": "integer", "minimum": 1 },
        "total_layouts": { "type": "integer", "minimum": 1 },
        "total_rollups": { "type": "integer", "minimum": 1 },
        "total_segments": { "type": "integer", "minimum": 1 },
        "total_steps": { "type": "integer", "minimum": 1 },
        "lookup_delta_entries": { "type": "integer", "minimum": 0 },
        "max_lookup_frontier_entries": { "type": "integer", "minimum": 0 },
        "source_template_commitment": { "$ref": "#/$defs/hash32" },
        "global_start_state_commitment": { "$ref": "#/$defs/hash32" },
        "global_end_state_commitment": { "$ref": "#/$defs/hash32" },
        "aggregation_template_commitment": { "$ref": "#/$defs/hash32" },
        "aggregated_chained_folded_interval_accumulator_commitment": { "$ref": "#/$defs/hash32" },
        "input_contract_commitment": { "$ref": "#/$defs/hash32" }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "phase29_contract",
        "phase30_manifest",
        "phase37_receipt"
      ],
      "properties": {
        "phase29_contract": { "$ref": "#/$defs/phase29_contract" },
        "phase30_manifest": { "$ref": "stwo-phase30-decoding-step-envelope-manifest.schema.json" },
        "phase37_receipt": { "$ref": "stwo-phase37-recursive-artifact-chain-harness-receipt.schema.json" }
      }
    },
    "segment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "segment_index",
        "step_start",
        "step_end",
        "total_steps",
        "phase29_contract",
        "phase30_manifest",
        "phase37_receipt",
        "phase37_receipt_commitment",
        "lookup_identity_commitment",
        "phase30_source_chain_commitment",
        "phase30_step_envelopes_commitment",
        "chain_start_boundary_commitment",
        "chain_end_boundary_commitment",
        "source_template_commitment",
        "aggregation_template_commitment",
        "phase34_shared_lookup_public_inputs_commitment",
        "input_lookup_rows_commitments_commitment",
        "output_lookup_rows_commitments_commitment",
        "shared_lookup_artifact_commitments_commitment",
        "static_lookup_registry_commitments_commitment"
      ],
      "properties": {
        "segment_index": { "type": "integer", "minimum": 0 },
        "step_start": { "type": "integer", "minimum": 0 },
        "step_end": { "type": "integer", "minimum": 1 },
        "total_steps": { "type": "integer", "minimum": 1 },
        "phase29_contract": { "$ref": "#/$defs/phase29_contract" },
        "phase30_manifest": { "$ref": "stwo-phase30-decoding-step-envelope-manifest.schema.json" },
        "phase37_receipt": { "$ref": "stwo-phase37-recursive-artifact-chain-harness-receipt.schema.json" },
        "phase37_receipt_commitment": { "$ref": "#/$defs/hash32" },
        "lookup_identity_commitment": { "$ref": "#/$defs/hash32" },
        "phase30_source_chain_commitment": { "$ref": "#/$defs/hash32" },
        "phase30_step_envelopes_commitment": { "$ref": "#/$defs/hash32" },
        "chain_start_boundary_commitment": { "$ref": "#/$defs/hash32" },
        "chain_end_boundary_commitment": { "$ref": "#/$defs/hash32" },
        "source_template_commitment": { "$ref": "#/$defs/hash32" },
        "aggregation_template_commitment": { "$ref": "#/$defs/hash32" },
        "phase34_shared_lookup_public_inputs_commitment": { "$ref": "#/$defs/hash32" },
        "input_lookup_rows_commitments_commitment": { "$ref": "#/$defs/hash32" },
        "output_lookup_rows_commitments_commitment": { "$ref": "#/$defs/hash32" },
        "shared_lookup_artifact_commitments_commitment": { "$ref": "#/$defs/hash32" },
        "static_lookup_registry_commitments_commitment": { "$ref": "#/$defs/hash32" }
      }
    }
  }
}
