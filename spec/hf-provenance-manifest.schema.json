{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/provable-transformer-vm/hf-provenance-manifest.schema.json",
  "title": "Hugging Face provenance manifest",
  "type": "object",
  "required": [
    "manifest_version",
    "semantic_scope",
    "commitment_hash_function",
    "hub_repo",
    "hub_revision",
    "tokenizer",
    "safetensors",
    "onnx_export",
    "release",
    "limitations",
    "commitments"
  ],
  "properties": {
    "manifest_version": { "const": "hf-provenance-manifest-v6" },
    "semantic_scope": { "const": "hf-release-provenance-boundary-v1" },
    "commitment_hash_function": { "const": "blake2b-256" },
    "hub_repo": { "type": "string", "minLength": 1 },
    "hub_revision": { "type": "string", "minLength": 1 },
    "tokenizer": { "$ref": "#/$defs/tokenizer" },
    "safetensors": {
      "type": "array",
      "items": { "$ref": "#/$defs/safetensors_file" }
    },
    "onnx_export": {
      "anyOf": [
        { "$ref": "#/$defs/onnx_export" },
        { "type": "null" }
      ]
    },
    "release": { "$ref": "#/$defs/release" },
    "attestation": {
      "anyOf": [
        { "$ref": "#/$defs/attestation" },
        { "type": "null" }
      ]
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "commitments": { "$ref": "#/$defs/commitments" }
  },
  "$defs": {
    "hash_blake2b_256_hex": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{64}$"
    },
    "hash_sha256_hex": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{64}$"
    },
    "file_commitment": {
      "type": "object",
      "required": ["path", "size_bytes", "blake2b_256", "sha256"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "size_bytes": { "type": "integer", "minimum": 0 },
        "blake2b_256": { "$ref": "#/$defs/hash_blake2b_256_hex" },
        "sha256": { "$ref": "#/$defs/hash_sha256_hex" }
      },
      "additionalProperties": false
    },
    "safetensors_file": {
      "type": "object",
      "required": [
        "path",
        "size_bytes",
        "blake2b_256",
        "sha256",
        "metadata_hash",
        "tensor_count"
      ],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "size_bytes": { "type": "integer", "minimum": 0 },
        "blake2b_256": { "$ref": "#/$defs/hash_blake2b_256_hex" },
        "sha256": { "$ref": "#/$defs/hash_sha256_hex" },
        "metadata_hash": { "$ref": "#/$defs/hash_blake2b_256_hex" },
        "tensor_count": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "tokenizer": {
      "type": "object",
      "required": [
        "tokenizer_id",
        "tokenizer_revision",
        "tokenizer_json",
        "tokenizer_config",
        "tokenization_transcript"
      ],
      "properties": {
        "tokenizer_id": { "type": "string", "minLength": 1 },
        "tokenizer_revision": { "type": "string", "minLength": 1 },
        "tokenizer_json": {
          "anyOf": [
            { "$ref": "#/$defs/file_commitment" },
            { "type": "null" }
          ]
        },
        "tokenizer_config": {
          "anyOf": [
            { "$ref": "#/$defs/file_commitment" },
            { "type": "null" }
          ]
        },
        "tokenization_transcript": {
          "anyOf": [
            { "$ref": "#/$defs/file_commitment" },
            { "type": "null" }
          ]
        }
      },
      "additionalProperties": false
    },
    "onnx_export": {
      "type": "object",
      "required": [
        "exporter",
        "exporter_version",
        "exporter_identity",
        "graph",
        "metadata",
        "metadata_identity",
        "graph_constraint_identity",
        "external_data_files"
      ],
      "properties": {
        "exporter": { "type": "string", "minLength": 1 },
        "exporter_version": {
          "anyOf": [
            { "type": "string", "minLength": 1 },
            { "type": "null" }
          ]
        },
        "exporter_identity": { "$ref": "#/$defs/onnx_exporter_identity" },
        "graph": { "$ref": "#/$defs/file_commitment" },
        "metadata": {
          "anyOf": [
            { "$ref": "#/$defs/file_commitment" },
            { "type": "null" }
          ]
        },
        "metadata_identity": {
          "anyOf": [
            { "$ref": "#/$defs/onnx_metadata_identity" },
            { "type": "null" }
          ]
        },
        "graph_constraint_identity": {
          "anyOf": [
            { "$ref": "#/$defs/onnx_graph_constraint_identity" },
            { "type": "null" }
          ]
        },
        "external_data_files": {
          "type": "array",
          "items": { "$ref": "#/$defs/file_commitment" }
        }
      },
      "additionalProperties": false
    },
    "onnx_exporter_identity": {
      "type": "object",
      "required": ["identity_version", "exporter", "exporter_version"],
      "properties": {
        "identity_version": { "const": "onnx-exporter-identity-v1" },
        "exporter": { "type": "string", "minLength": 1 },
        "exporter_version": {
          "anyOf": [
            { "type": "string", "minLength": 1 },
            { "type": "null" }
          ]
        }
      },
      "additionalProperties": false
    },
    "onnx_metadata_identity": {
      "type": "object",
      "required": [
        "identity_version",
        "format_version",
        "ir_version",
        "opset_version",
        "input_dim",
        "output_dim",
        "input_encoding",
        "output_encoding",
        "instruction_count"
      ],
      "properties": {
        "identity_version": { "const": "onnx-program-metadata-identity-v1" },
        "format_version": { "type": "integer", "minimum": 0 },
        "ir_version": { "type": "integer", "minimum": 0 },
        "opset_version": { "type": "integer", "minimum": 0 },
        "input_dim": { "type": "integer", "minimum": 0 },
        "output_dim": { "type": "integer", "minimum": 0 },
        "input_encoding": { "type": "string", "minLength": 1 },
        "output_encoding": { "type": "string", "minLength": 1 },
        "instruction_count": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "onnx_graph_constraint_identity": {
      "type": "object",
      "required": [
        "identity_version",
        "input_dim",
        "output_dim",
        "input_encoding",
        "output_encoding",
        "input_layout_hash",
        "output_layout_hash",
        "instruction_count",
        "instruction_table_hash"
      ],
      "properties": {
        "identity_version": { "const": "onnx-graph-constraint-identity-v1" },
        "input_dim": { "type": "integer", "minimum": 0 },
        "output_dim": { "type": "integer", "minimum": 0 },
        "input_encoding": { "type": "string", "minLength": 1 },
        "output_encoding": { "type": "string", "minLength": 1 },
        "input_layout_hash": {
          "anyOf": [
            { "$ref": "#/$defs/hash_blake2b_256_hex" },
            { "type": "null" }
          ]
        },
        "output_layout_hash": {
          "anyOf": [
            { "$ref": "#/$defs/hash_blake2b_256_hex" },
            { "type": "null" }
          ]
        },
        "instruction_count": { "type": "integer", "minimum": 0 },
        "instruction_table_hash": { "$ref": "#/$defs/hash_blake2b_256_hex" }
      },
      "additionalProperties": false
    },
    "release": {
      "type": "object",
      "required": ["model_card", "doi", "datasets", "notes"],
      "properties": {
        "model_card": {
          "anyOf": [
            { "$ref": "#/$defs/file_commitment" },
            { "type": "null" }
          ]
        },
        "doi": {
          "anyOf": [
            { "type": "string", "minLength": 1 },
            { "type": "null" }
          ]
        },
        "datasets": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "notes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    },
    "attestation_subject": {
      "type": "object",
      "required": ["role", "path", "sha256"],
      "properties": {
        "role": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "$ref": "#/$defs/hash_sha256_hex" }
      },
      "additionalProperties": false
    },
    "attestation": {
      "type": "object",
      "required": [
        "attestation_version",
        "builder_id",
        "build_invocation_id",
        "source_repository",
        "source_revision",
        "subjects"
      ],
      "properties": {
        "attestation_version": { "const": "hf-attestation-metadata-v1" },
        "builder_id": {
          "anyOf": [
            { "type": "string", "minLength": 1 },
            { "type": "null" }
          ]
        },
        "build_invocation_id": {
          "anyOf": [
            { "type": "string", "minLength": 1 },
            { "type": "null" }
          ]
        },
        "source_repository": {
          "anyOf": [
            { "type": "string", "minLength": 1 },
            { "type": "null" }
          ]
        },
        "source_revision": {
          "anyOf": [
            { "type": "string", "minLength": 1 },
            { "type": "null" }
          ]
        },
        "subjects": {
          "type": "array",
          "items": { "$ref": "#/$defs/attestation_subject" }
        }
      },
      "additionalProperties": false
    },
    "commitments": {
      "type": "object",
      "required": [
        "hub_binding_hash",
        "tokenizer_hash",
        "safetensors_manifest_hash",
        "onnx_export_hash",
        "onnx_exporter_identity_hash",
        "onnx_metadata_identity_hash",
        "onnx_graph_constraint_identity_hash",
        "release_metadata_hash",
        "limitations_hash"
      ],
      "properties": {
        "hub_binding_hash": { "$ref": "#/$defs/hash_blake2b_256_hex" },
        "tokenizer_hash": { "$ref": "#/$defs/hash_blake2b_256_hex" },
        "safetensors_manifest_hash": { "$ref": "#/$defs/hash_blake2b_256_hex" },
        "onnx_export_hash": { "$ref": "#/$defs/hash_blake2b_256_hex" },
        "onnx_exporter_identity_hash": { "$ref": "#/$defs/hash_blake2b_256_hex" },
        "onnx_metadata_identity_hash": { "$ref": "#/$defs/hash_blake2b_256_hex" },
        "onnx_graph_constraint_identity_hash": { "$ref": "#/$defs/hash_blake2b_256_hex" },
        "release_metadata_hash": { "$ref": "#/$defs/hash_blake2b_256_hex" },
        "attestation_hash": { "$ref": "#/$defs/hash_blake2b_256_hex" },
        "limitations_hash": { "$ref": "#/$defs/hash_blake2b_256_hex" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
