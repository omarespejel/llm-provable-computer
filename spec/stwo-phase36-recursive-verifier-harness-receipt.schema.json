{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://llm-provable-computer/spec/stwo-phase36-recursive-verifier-harness-receipt.schema.json",
  "title": "S-two Phase 36 Recursive Verifier Harness Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "proof_backend",
    "receipt_version",
    "semantic_scope",
    "verifier_harness",
    "proof_backend_version",
    "statement_version",
    "step_relation",
    "required_recursion_posture",
    "recursive_verification_claimed",
    "cryptographic_compression_claimed",
    "target_manifest_verified",
    "source_binding_verified",
    "phase35_manifest_version",
    "phase35_semantic_scope",
    "phase35_recursive_target_manifest_commitment",
    "phase32_recursive_statement_contract_commitment",
    "phase33_recursive_public_inputs_commitment",
    "phase34_shared_lookup_public_inputs_commitment",
    "total_steps",
    "phase30_source_chain_commitment",
    "phase30_step_envelopes_commitment",
    "chain_start_boundary_commitment",
    "chain_end_boundary_commitment",
    "input_lookup_rows_commitments_commitment",
    "output_lookup_rows_commitments_commitment",
    "shared_lookup_artifact_commitments_commitment",
    "static_lookup_registry_commitments_commitment",
    "recursive_verifier_harness_receipt_commitment"
  ],
  "properties": {
    "proof_backend": { "const": "stwo" },
    "receipt_version": { "const": "stwo-phase36-recursive-verifier-harness-receipt-v1" },
    "semantic_scope": { "const": "stwo_execution_parameterized_recursive_verifier_harness_receipt" },
    "verifier_harness": { "const": "source-bound-target-verifier-v1" },
    "proof_backend_version": { "const": "stwo-phase12-decoding-family-v9" },
    "statement_version": { "const": "statement-v1" },
    "step_relation": { "const": "decoding_step_v2" },
    "required_recursion_posture": { "const": "pre-recursive-proof-carrying-aggregation" },
    "recursive_verification_claimed": { "const": false },
    "cryptographic_compression_claimed": { "const": false },
    "target_manifest_verified": { "const": true },
    "source_binding_verified": { "const": true },
    "phase35_manifest_version": { "const": "stwo-phase35-recursive-compression-target-manifest-v1" },
    "phase35_semantic_scope": { "const": "stwo_execution_parameterized_recursive_compression_target_manifest" },
    "phase35_recursive_target_manifest_commitment": { "$ref": "#/$defs/hash32" },
    "phase32_recursive_statement_contract_commitment": { "$ref": "#/$defs/hash32" },
    "phase33_recursive_public_inputs_commitment": { "$ref": "#/$defs/hash32" },
    "phase34_shared_lookup_public_inputs_commitment": { "$ref": "#/$defs/hash32" },
    "total_steps": { "type": "integer", "minimum": 1 },
    "phase30_source_chain_commitment": { "$ref": "#/$defs/hash32" },
    "phase30_step_envelopes_commitment": { "$ref": "#/$defs/hash32" },
    "chain_start_boundary_commitment": { "$ref": "#/$defs/hash32" },
    "chain_end_boundary_commitment": { "$ref": "#/$defs/hash32" },
    "input_lookup_rows_commitments_commitment": { "$ref": "#/$defs/hash32" },
    "output_lookup_rows_commitments_commitment": { "$ref": "#/$defs/hash32" },
    "shared_lookup_artifact_commitments_commitment": { "$ref": "#/$defs/hash32" },
    "static_lookup_registry_commitments_commitment": { "$ref": "#/$defs/hash32" },
    "recursive_verifier_harness_receipt_commitment": { "$ref": "#/$defs/hash32" }
  },
  "$defs": {
    "hash32": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  }
}
